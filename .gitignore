# =============================================================================
# Workshop secrets — NEVER commit these
# =============================================================================
# The actual Vault password file. Attendees copy .vault-pass.example to
# .vault-pass and put their workshop password in it. The .example file IS
# committed; the real one is not.
.vault-pass
.vault_pass
*.vault_pass

# The encrypted vault file with attendee-specific Windows credentials.
# The vault.yml.example template IS committed; the real vault.yml is not.
inventory/group_vars/windows/vault.yml

# Per-attendee credentials CSV generated during Azure provisioning.
# Contains SSH passwords for attendee control nodes — do NOT commit.
provisioning/azure/attendee-credentials.csv
provisioning/azure/attendee-credentials-*.csv

# Azure service principal credentials used by the provisioning playbook
provisioning/azure/credentials.yml
provisioning/azure/credentials.json
.azure-credentials

# =============================================================================
# Ansible
# =============================================================================
*.retry
.ansible/
*.log
ansible.log

# Ansible Galaxy installed roles (we vendor explicit ones, so this catches drift)
roles/galaxy/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
.env
*.egg-info/
dist/
build/

# =============================================================================
# Vagrant
# =============================================================================
.vagrant/
*.box

# =============================================================================
# IDE & editor files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# =============================================================================
# Output captures (the real ones go in docs/captures/, but ignore working files)
# =============================================================================
docs/captures/scratch/
docs/captures/*.tmp
docs/captures/*.session

# =============================================================================
# Bicep build artifacts
# =============================================================================
provisioning/bicep/*.json
!provisioning/bicep/parameters.example.json

# =============================================================================
# OS / system noise
# =============================================================================
.directory
.Trash-*
$RECYCLE.BIN/
