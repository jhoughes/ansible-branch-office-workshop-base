#cloud-config
# =============================================================================
# cloud-init configuration for the attendee control node
# =============================================================================
# This file is rendered per-attendee by the attendee-rg role and passed to the
# Azure VM via the custom_data parameter. cloud-init runs it on first boot
# and bakes the result into the image.
#
# Goals:
#   1. Install ansible-core via pip (apt gives 2.10.8 which is too old for
#      the workshop's pinned collections — they need ansible-core 2.14+)
#   2. Install Python deps for pywinrm
#   3. Generate an SSH keypair and push it to the lab hosts so Ansible can
#      connect from control → web1/web2 without password prompts
#   4. Clone the workshop repo into /home/{{ attendee_ssh_username }}/workshop
#   5. Set ownership so the attendee can edit files
#   6. Pre-install ansible-galaxy collections that the workshop needs
#   7. Create .vault-pass from the example so ansible.cfg doesn't break
#
# Anything that would require running playbooks against the lab itself goes in
# the workshop's own preflight/check.yml playbook, NOT here. Cloud-init is for
# bootstrapping the control node, not the entire lab.
# =============================================================================

package_update: true
package_upgrade: false   # don't waste 10 minutes patching on first boot

packages:
  - python3-pip
  - python3-venv
  - git
  - jq
  - tree
  - vim
  - nano
  - tmux
  - htop
  - sshpass        # needed for ssh-copy-id to web1/web2 during bootstrap

write_files:
  # A small README in the attendee's home directory pointing them at the workshop
  - path: /home/{{ attendee_ssh_username }}/README.txt
    permissions: '0644'
    content: |
      Welcome to the Ansible Branch Office Workshop!

      The workshop repository is at:
        ~/workshop

      Get started:
        cd ~/workshop
        ansible-playbook preflight/check.yml

      Your instructor will walk you through the rest. If you fall behind
      during a section, look in checkpoints/section-X.Y/ for a complete
      working snapshot.

      Have fun!

  # An ansible.cfg fragment in the attendee's home that ensures the workshop's
  # cfg is picked up. The workshop's own ansible.cfg in the repo root takes
  # precedence when ansible-playbook is run from inside the repo, but having
  # this here means ansible commands run from the home directory still work.
  - path: /home/{{ attendee_ssh_username }}/.ansible.cfg
    permissions: '0644'
    content: |
      [defaults]
      host_key_checking = False
      stdout_callback = yaml
      interpreter_python = auto_silent

  # /etc/hosts entries for the lab hosts. This is what makes the workshop's
  # inventory file (inventory/hosts.yml) work — it references hosts by short
  # name (web1, web2, mgmt1) and relies on /etc/hosts to resolve them to the
  # per-attendee private IPs (10.<attendee_number>.0.X). Without these entries,
  # every Ansible task targeting web1/web2/mgmt1 would fail with a DNS error.
  - path: /etc/hosts.workshop-additions
    permissions: '0644'
    content: |
      # Workshop lab host entries — written by cloud-init at provisioning time.
      # See inventory/hosts.yml in the workshop repo for how these are used.
      {{ host_private_ips.web1 }}   web1
      {{ host_private_ips.web2 }}   web2
      {{ host_private_ips.mgmt1 }}  mgmt1

runcmd:
  # -------------------------------------------------------------------------
  # Step 1: Append /etc/hosts entries FIRST — everything below needs name
  # resolution to work (ssh-copy-id to web1/web2 uses these names).
  # -------------------------------------------------------------------------
  - cat /etc/hosts.workshop-additions >> /etc/hosts

  # -------------------------------------------------------------------------
  # Step 2: Install ansible-core and pywinrm via pip.
  # The apt 'ansible' package on Ubuntu 22.04 gives 2.10.8 (from 2021),
  # which is too old for the workshop's pinned collections. pip gives us
  # a current version (2.16+).
  # --break-system-packages is needed on Ubuntu 22.04+ due to PEP 668.
  # The fallback without the flag handles older pip versions.
  # -------------------------------------------------------------------------
  - pip3 install ansible-core --break-system-packages || pip3 install ansible-core
  - pip3 install "pywinrm[kerberos]" requests --break-system-packages || pip3 install "pywinrm[kerberos]" requests

  # -------------------------------------------------------------------------
  # Step 3: Fix home directory ownership BEFORE doing anything as the
  # attendee user. The pip installs above run as root and create cache
  # files inside /home/attendee/ that change ownership. Without this
  # chown, the git clone and ansible-galaxy steps below fail with
  # "Permission denied."
  # -------------------------------------------------------------------------
  - chown -R {{ attendee_ssh_username }}:{{ attendee_ssh_username }} /home/{{ attendee_ssh_username }}

  # -------------------------------------------------------------------------
  # Step 4: Generate an SSH keypair for the attendee and push it to
  # web1 and web2 so Ansible can connect without password prompts.
  # sshpass feeds the generated SSH password non-interactively.
  # The -o StrictHostKeyChecking=no avoids the first-connect prompt.
  # -------------------------------------------------------------------------
  - sudo -u {{ attendee_ssh_username }} ssh-keygen -t ed25519 -f /home/{{ attendee_ssh_username }}/.ssh/id_ed25519 -N "" -q
  - sshpass -p "{{ generated_ssh_password }}" ssh-copy-id -o StrictHostKeyChecking=no -i /home/{{ attendee_ssh_username }}/.ssh/id_ed25519.pub {{ attendee_ssh_username }}@web1
  - sshpass -p "{{ generated_ssh_password }}" ssh-copy-id -o StrictHostKeyChecking=no -i /home/{{ attendee_ssh_username }}/.ssh/id_ed25519.pub {{ attendee_ssh_username }}@web2

  # -------------------------------------------------------------------------
  # Step 5: Clone the workshop repo and install Galaxy collections.
  # The repo must be PUBLIC on GitHub for this to work.
  # -------------------------------------------------------------------------
  - sudo -u {{ attendee_ssh_username }} git clone --branch {{ workshop_repo_branch }} {{ workshop_repo_url }} /home/{{ attendee_ssh_username }}/workshop
  - sudo -u {{ attendee_ssh_username }} ansible-galaxy collection install -r /home/{{ attendee_ssh_username }}/workshop/requirements.yml

  # -------------------------------------------------------------------------
  # Step 6: Create .vault-pass from the example. ansible.cfg references
  # vault_password_file = .vault-pass, and without it every playbook run
  # (including preflight) fails immediately.
  # -------------------------------------------------------------------------
  - sudo -u {{ attendee_ssh_username }} cp /home/{{ attendee_ssh_username }}/workshop/.vault-pass.example /home/{{ attendee_ssh_username }}/workshop/.vault-pass

  # -------------------------------------------------------------------------
  # Step 7: Final ownership sweep. Belt-and-suspenders — catches anything
  # that leaked root ownership during the steps above.
  # -------------------------------------------------------------------------
  - chown -R {{ attendee_ssh_username }}:{{ attendee_ssh_username }} /home/{{ attendee_ssh_username }}

  # -------------------------------------------------------------------------
  # Step 8: Drop a marker so the preflight playbook can confirm cloud-init
  # finished successfully.
  # -------------------------------------------------------------------------
  - touch /var/lib/cloud/instance/workshop-bootstrap-complete

# Make sure the attendee can sudo without a password (lab convenience, not production).
bootcmd:
  - echo "{{ attendee_ssh_username }} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-{{ attendee_ssh_username }}-nopasswd
  - chmod 0440 /etc/sudoers.d/90-{{ attendee_ssh_username }}-nopasswd

final_message: "Workshop control node bootstrap complete in $UPTIME seconds. Ready for attendee."
